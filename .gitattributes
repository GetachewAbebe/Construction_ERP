# Enforce LF line endings for all text files in this repo.
# This prevents the CRLF<->LF cycle on Windows that causes
# repeated Pint `line_ending` style failures in CI.

* text=auto eol=lf

# PHP & web source files — always LF
*.php   text eol=lf
*.blade.php text eol=lf
*.js    text eol=lf
*.ts    text eol=lf
*.css   text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.env   text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.xml   text eol=lf
*.svg   text eol=lf
*.sh    text eol=lf

# Binary files — never touch line endings
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.otf   binary
*.zip   binary
*.gz    binary
*.pdf   binary
